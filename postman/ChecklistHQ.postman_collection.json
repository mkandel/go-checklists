              "mode": "raw",
              "raw": "carol,hunter22,Carol Example,false,carol@example.com\ndave,hunter22,Dave Example,true,dave@example.com"
            },
            "url": { "raw": "{{base_url}}/api/admin/users/bulk", "host": ["{{base_url}}"], "path": ["api", "admin", "users", "bulk"] },
            "description": "Raw CSV body, NO header row. Columns: username,password,name[,is_admin[,email]]. Requires admin. Response is an array of per-row results (row, username, status, error, user)."
          }
        }
      ]
    },
    {
      "name": "Templates",
      "item": [
        {
          "name": "List Templates",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/templates", "host": ["{{base_url}}"], "path": ["api", "templates"] }
          }
        },
        {
          "name": "Get Template",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/templates/{{template_id}}", "host": ["{{base_url}}"], "path": ["api", "templates", "{{template_id}}"] }
          }
        },
        {
          "name": "Get Latest Template By Name",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/templates/latest/{{template_name}}", "host": ["{{base_url}}"], "path": ["api", "templates", "latest", "{{template_name}}"] }
          }
        },
        {
          "name": "Create Template Version",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{template_name}}\",\n  \"items\": [\n    { \"name\": \"Step 1\", \"validation_ref\": \"\" },\n    { \"name\": \"Step 2\", \"validation_ref\": \"\" }\n  ]\n}"
            },
            "url": { "raw": "{{base_url}}/api/templates", "host": ["{{base_url}}"], "path": ["api", "templates"] },
            "description": "Requires admin. Creating with an existing name adds a new version rather than replacing the old one."
          }
        }
      ]
    },
    {
      "name": "Groups",
