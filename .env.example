DATABASE_URL=postgres://checklists:checklists@localhost:5432/checklists?sslmode=disable
LISTEN_HOST=
API_PORT=8080
WEB_PORT=8081
# The app runs behind the Caddy reverse proxy started by docker-compose.yml
# (see Caddyfile), which fronts port 80 and forwards to WEB_PORT above.
# TRUST_PROXY tells the app to honor Caddy's X-Forwarded-Proto/-For headers
# for cookie security and per-client rate limiting. Only set this to true
# when a trusted reverse proxy is actually in front — never for a
# directly internet-facing app.
TRUST_PROXY=true
